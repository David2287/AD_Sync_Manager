# ── Server ────────────────────────────────────────────────────────────────────
SERVER_PORT=8080
GIN_MODE=release          # debug | release

# ── Active Directory ──────────────────────────────────────────────────────────
AD_URL=ldaps://dc.company.com:636
AD_BASE_DN=DC=company,DC=com
AD_EMPLOYEE_OU=OU=Employees,DC=company,DC=com
AD_BIND_DN=CN=svc-adsync,OU=ServiceAccounts,DC=company,DC=com
AD_BIND_PASSWORD=changeme
AD_TLS_SKIP_VERIFY=false  # set true only in dev/test

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-at-least-32-random-bytes
JWT_EXPIRY=8h
JWT_ISSUER=ad-sync-manager

# ── Database (SQLite) ─────────────────────────────────────────────────────────
DATABASE_DSN=file:/data/adsync.db?cache=shared&mode=rwc

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info            # debug | info | warn | error
LOG_FORMAT=json           # json | console

# ── RBAC Groups ───────────────────────────────────────────────────────────────
# CN of the AD group whose members get the "admin" role
AD_ADMIN_GROUP=CN=AD-Sync-Admins,OU=Groups,DC=company,DC=com
